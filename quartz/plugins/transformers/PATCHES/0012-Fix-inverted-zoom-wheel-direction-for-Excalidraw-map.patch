From 6040b96dd5e2a965d9c0ae396b73267567c4998e Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Sun, 16 Nov 2025 22:49:33 +0000
Subject: [PATCH 12/12] Fix inverted zoom wheel direction for Excalidraw maps

Swap zoom delta values so that:
- Wheel forward (scroll up) zooms IN
- Wheel backward (scroll down) zooms OUT

This matches standard map navigation expectations.
---
 quartz/components/scripts/excalidraw.inline.ts | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/quartz/components/scripts/excalidraw.inline.ts b/quartz/components/scripts/excalidraw.inline.ts
index f569749..1d9fcdf 100644
--- a/quartz/components/scripts/excalidraw.inline.ts
+++ b/quartz/components/scripts/excalidraw.inline.ts
@@ -146,7 +146,7 @@ class PanZoom {
   private onWheel(event: WheelEvent) {
     event.preventDefault()
 
-    const delta = event.deltaY > 0 ? 1.1 : 0.9
+    const delta = event.deltaY > 0 ? 0.9 : 1.1
     this.zoom(delta, this.getPoint(event))
   }
 
