+
+  public zoom(factor: number, point?: { x: number; y: number }) {
+    const oldScale = this.scale
+    this.scale *= factor
+
+    // Limit zoom
+    if (this.scale < 0.1) {
+      this.scale = 0.1
+      return
+    }
+    if (this.scale > 10) {
+      this.scale = 10
+      return
+    }
